# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_INPUT_TOPIC=transactions
KAFKA_NORMAL_TOPIC=normal_transactions
KAFKA_ANOMALY_TOPIC=anomaly_transactions
KAFKA_CONSUMER_GROUP=fraud-detector
KAFKA_BATCH_SIZE=100
KAFKA_BATCH_TIMEOUT_MS=1000

# Model Configuration
MODEL_PATH=models/fraud_model.joblib
CONFIG_PATH=models/feature_config.json
MODEL_VERSION=1.0

# Predict Service
PREDICT_SERVICE_HOST=0.0.0.0
PREDICT_SERVICE_PORT=8000

# Monitoring
METRICS_PORT=9090
